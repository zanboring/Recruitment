<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.recruitment.mapper.SysLogMapper">

    <resultMap id="SysLogResultMap" type="com.example.recruitment.entity.SysLog">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="action" property="action"/>
        <result column="method" property="method"/>
        <result column="uri" property="uri"/>
        <result column="ip" property="ip"/>
        <result column="params" property="params"/>
        <result column="success" property="success"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.recruitment.entity.SysLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_log (username, action, method, uri, ip, params, success, error_msg, created_at)
        VALUES (#{username}, #{action}, #{method}, #{uri}, #{ip}, #{params}, #{success}, #{errorMsg}, #{createdAt})
    </insert>

    <select id="selectByPage" resultMap="SysLogResultMap">
        SELECT * FROM sys_log ORDER BY created_at DESC
    </select>

    <select id="selectCount" resultType="int">
        SELECT COUNT(*) FROM sys_log
    </select>

    <select id="selectByUsername" parameterType="string" resultMap="SysLogResultMap">
        SELECT * FROM sys_log WHERE username = #{username} ORDER BY created_at DESC
    </select>

    <delete id="deleteBefore" parameterType="java.time.LocalDateTime">
        DELETE FROM sys_log WHERE created_at &lt; #{before}
    </delete>
    
    <select id="selectByConditions" resultMap="SysLogResultMap">
        SELECT * FROM sys_log
        <where>
            <if test="username != null and username != ''">AND username LIKE CONCAT('%', #{username}, '%')</if>
            <if test="type != null and type != ''">AND action = #{type}</if>
            <if test="startTime != null">AND created_at &gt;= #{startTime}</if>
            <if test="endTime != null">AND created_at &lt;= #{endTime}</if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{size} OFFSET #{page}
    </select>
    
    <select id="countByConditions" resultType="int">
        SELECT COUNT(*) FROM sys_log
        <where>
            <if test="username != null and username != ''">AND username LIKE CONCAT('%', #{username}, '%')</if>
            <if test="type != null and type != ''">AND action = #{type}</if>
            <if test="startTime != null">AND created_at &gt;= #{startTime}</if>
            <if test="endTime != null">AND created_at &lt;= #{endTime}</if>
        </where>
    </select>
    
    <select id="selectAllByConditions" resultMap="SysLogResultMap">
        SELECT * FROM sys_log
        <where>
            <if test="username != null and username != ''">AND username LIKE CONCAT('%', #{username}, '%')</if>
            <if test="type != null and type != ''">AND action = #{type}</if>
            <if test="startTime != null">AND created_at &gt;= #{startTime}</if>
            <if test="endTime != null">AND created_at &lt;= #{endTime}</if>
        </where>
        ORDER BY created_at DESC
    </select>
</mapper>
